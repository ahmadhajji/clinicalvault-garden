THEME=https://raw.githubusercontent.com/kepano/obsidian-minimal/master/theme.css
BASE_THEME=light
SITE_BASE_URL=clinicalvault.me
SITE_NAME_HEADER=Clinical Vault
SITE_MAIN_LANGUAGE=en

dgHomeLink=true
dgEnableSearch=true
dgShowBacklinks=true
dgShowLocalGraph=false
dgShowToc=true
dgLinkPreview=true
dgShowTags=true

SHOW_CREATED_TIMESTAMP=true
SHOW_UPDATED_TIMESTAMP=true
TIMESTAMP_FORMAT=yyyy-MM-dd

# Cloudflare Web Analytics token from Cloudflare dashboard
CLOUDFLARE_ANALYTICS_TOKEN=

# Giscus configuration (required for comments)
GISCUS_REPO=
GISCUS_REPO_ID=
GISCUS_CATEGORY=General
GISCUS_CATEGORY_ID=
GISCUS_MAPPING=pathname
GISCUS_STRICT=0
GISCUS_REACTIONS_ENABLED=1
GISCUS_EMIT_METADATA=0
GISCUS_INPUT_POSITION=top
GISCUS_LANG=en
GISCUS_THEME=preferred_color_scheme

# --- Modern app auth/comments/search ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_COMMENTS_ENABLED=true

# Server-side Supabase integration (Vercel functions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive realtime sync source (service account)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_WEBHOOK_TOKEN=

# Optional endpoint protection for manual reconcile
SYNC_SECRET=
