{% if tags and tags.indexOf('gardenEntry') != -1 %}
<section class="cv-home-intro" aria-label="Site intro">
  <p class="cv-eyebrow">Clinical Vault</p>
  <h2>Personal notes on medicine, study systems, and clinical learning.</h2>
  <p>
    A focused, continuously updated knowledge base published from Obsidian.
  </p>
  <div class="cv-home-stats" aria-label="Site stats">
    <span><strong>{{ userComputed.noteCount }}</strong> published notes</span>
    <span><strong>{{ userComputed.topicCount }}</strong> active topics</span>
    {% if userComputed.lastPublished %}<span>latest update <strong>{{ userComputed.lastPublished }}</strong></span>{% endif %}
  </div>
</section>

<section class="cv-home-grid" aria-label="Homepage sections">
  <article class="cv-panel">
    <h3>Latest Notes</h3>
    {% if userComputed.latestNotes and userComputed.latestNotes.length %}
    <ul class="cv-latest-list">
      {% for item in userComputed.latestNotes %}
      <li>
        <a href="{{ item.url }}">{{ item.title }}</a>
        {% if item.dateLabel %}<time datetime="{{ item.dateLabel }}">{{ item.dateLabel }}</time>{% endif %}
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p>No published notes yet.</p>
    {% endif %}
  </article>

  <article class="cv-panel">
    <h3>Browse By Topic</h3>
    {% if userComputed.topTags and userComputed.topTags.length %}
    <div class="cv-tag-cloud">
      {% for tag in userComputed.topTags %}
      <a class="tag" onclick="toggleTagSearch(this)">#{{ tag.name }} <span>{{ tag.count }}</span></a>
      {% endfor %}
    </div>
    {% else %}
    <p>No topics yet.</p>
    {% endif %}
  </article>
</section>
{% endif %}
