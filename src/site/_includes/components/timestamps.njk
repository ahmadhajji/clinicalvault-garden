<script src=" https://fastly.jsdelivr.net/npm/luxon@3.2.1/build/global/luxon.min.js "></script>
<script defer>
  const TIMESTAMP_FORMAT = "{{meta.timestampSettings.timestampFormat}}";
  document.querySelectorAll(".human-date").forEach((el) => {
    const rawDate = (el.getAttribute("data-date") || el.innerText || "").trim();
    let parsedDate = luxon.DateTime.fromISO(rawDate);

    if (!parsedDate.isValid) {
      parsedDate = luxon.DateTime.fromSQL(rawDate);
    }
    if (!parsedDate.isValid) {
      parsedDate = luxon.DateTime.fromFormat(rawDate, "yyyy-MM-dd");
    }
    if (!parsedDate.isValid) {
      parsedDate = luxon.DateTime.fromRFC2822(rawDate);
    }

    if (parsedDate.isValid) {
      el.innerHTML = parsedDate.toFormat(TIMESTAMP_FORMAT);
    } else {
      el.innerHTML = rawDate;
    }
  });
</script>
