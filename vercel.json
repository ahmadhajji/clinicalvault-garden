{
    "outputDirectory": "modern/apps/web/dist",
    "installCommand": "npm install && npm run modern:install",
    "buildCommand": "npm run modern:build",
    "devCommand": "npm start",
    "routes": [
        { "handle": "filesystem" },
        { "src": "/library", "dest": "/index.html" },
        { "src": "/library/(.*)", "dest": "/index.html" },
        { "src": "/note", "dest": "/index.html" },
        { "src": "/note/(.*)", "dest": "/index.html" }
      ]
}
