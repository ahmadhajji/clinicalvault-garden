{
    "outputDirectory": "modern/apps/web/dist",
    "installCommand": "npm run modern:install",
    "buildCommand": "npm run modern:build",
    "devCommand": "npm start",
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/index.html" }
      ]
}
